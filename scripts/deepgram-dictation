#!/home/mfranc/.local/share/mise/installs/python/3.14.0/bin/python3

import os
import sys
import signal
import argparse
import subprocess

# Parse arguments
parser = argparse.ArgumentParser()
parser.add_argument('--claude', action='store_true', help='Send transcript to Claude CLI')
args = parser.parse_args()

MODE = 'claude' if args.claude else 'type'

API_KEY_FILE = "/home/mfranc/deepgram_api_key"
PIDFILE = "/tmp/deepgram-dictation.pid"

# Accumulated transcript for claude mode
transcript_buffer = []
cleanup_done = False

# Write PID file
with open(PIDFILE, 'w') as f:
    f.write(str(os.getpid()))

def cleanup_and_exit(signum=None, frame=None):
    global cleanup_done, capturing
    if cleanup_done:
        return
    cleanup_done = True

    # Stop mic capture if it was started (may not exist if we exit before setup)
    capturing = False
    mic = globals().get('_mic_stream')
    if mic is not None:
        try:
            mic.stop_stream()  # unblocks any in-flight read() in capture thread
        except Exception:
            pass
    # Wait for capture thread to leave read() before tearing down PortAudio state
    cap_thread = globals().get('_capture_thread')
    if cap_thread is not None and cap_thread.is_alive():
        cap_thread.join(timeout=1.0)
    if mic is not None:
        try:
            mic.close()
        except Exception:
            pass
    pa = globals().get('_pa')
    if pa is not None:
        try:
            pa.terminate()
        except Exception:
            pass

    try:
        os.remove(PIDFILE)
    except:
        pass

    # In claude mode, send accumulated transcript to claude in a terminal
    if MODE == 'claude' and transcript_buffer:
        full_text = ' '.join(transcript_buffer)
        import subprocess
        subprocess.Popen(['alacritty', '-e', 'claude', full_text])

    sys.exit(0)

signal.signal(signal.SIGTERM, cleanup_and_exit)
signal.signal(signal.SIGINT, cleanup_and_exit)

try:
    with open(API_KEY_FILE) as f:
        api_key = f.read().strip()
        os.environ["DEEPGRAM_API_KEY"] = api_key
except FileNotFoundError:
    msg = f"API key file not found at {API_KEY_FILE}"
    print(f"Error: {msg}", file=sys.stderr)
    subprocess.run(['notify-send', '-u', 'critical', 'Dictation Error', msg])
    sys.exit(1)

if not api_key:
    msg = "DEEPGRAM_API_KEY is empty"
    print(f"Error: {msg}", file=sys.stderr)
    subprocess.run(['notify-send', '-u', 'critical', 'Dictation Error', msg])
    sys.exit(1)

import time
import threading
import queue
import pyaudio

FORMAT = pyaudio.paInt16
CHANNELS = 1
RATE = 16000
CHUNK = 2000
SILENCE_TIMEOUT = 10.0  # seconds of silence before auto-stop (after first speech)
PRE_SPEECH_TIMEOUT = 30.0  # seconds with no speech ever before giving up

# Open mic and start capturing into a queue BEFORE the slow Deepgram setup,
# so the first 1-2s of speech aren't lost while the websocket connects.
# Bounded queue caps memory if Deepgram setup hangs (~32KB/s, so 240 chunks ≈ 30s).
audio_queue = queue.Queue(maxsize=240)
capturing = True

_pa = pyaudio.PyAudio()
_mic_stream = _pa.open(
    format=FORMAT,
    channels=CHANNELS,
    rate=RATE,
    input=True,
    frames_per_buffer=CHUNK,
)

def _capture_loop():
    while capturing:
        try:
            data = _mic_stream.read(CHUNK, exception_on_overflow=False)
        except Exception:
            break
        try:
            audio_queue.put(data, timeout=1.0)
        except queue.Full:
            # Drop oldest if consumer is stalled
            try:
                audio_queue.get_nowait()
                audio_queue.put_nowait(data)
            except (queue.Empty, queue.Full):
                pass

_capture_thread = threading.Thread(target=_capture_loop, daemon=True)
_capture_thread.start()

from deepgram import DeepgramClient
from deepgram.core.events import EventType

def type_text(text):
    """Type text into active window using xdotool"""
    subprocess.run(['xdotool', 'type', '--', text], check=False)

def backspace(n):
    """Delete n characters by sending BackSpace keys"""
    if n > 0:
        subprocess.run(['xdotool', 'key', '--repeat', str(n), 'BackSpace'], check=False)

def main():
    global capturing
    client = DeepgramClient()
    start_time = time.time()
    last_speech_time = time.time()
    has_received_speech = False
    running = True

    try:
        with client.listen.v1.connect(
            model="nova-3",
            language="en-US",
            smart_format="false",
            punctuate="false",
            interim_results="true",
            endpointing="100",
            encoding="linear16",
            sample_rate=str(RATE),
            mip_opt_out="true",
        ) as connection:

            # Track the current interim text so we can diff against it
            current_interim = ''

            def on_message(message):
                nonlocal last_speech_time, has_received_speech, current_interim
                msg_type = getattr(message, 'type', '')

                # Handle transcript results
                if hasattr(message, 'channel'):
                    is_final = getattr(message, 'is_final', True)
                    alternatives = message.channel.alternatives
                    if alternatives and len(alternatives) > 0:
                        transcript = alternatives[0].transcript
                        if transcript:
                            last_speech_time = time.time()
                            has_received_speech = True
                            if MODE == 'type':
                                # Find common prefix, only backspace/retype the diff
                                common = 0
                                for a, b in zip(current_interim, transcript):
                                    if a == b:
                                        common += 1
                                    else:
                                        break
                                backspace(len(current_interim) - common)
                                type_text(transcript[common:])
                                if is_final:
                                    type_text(' ')
                                    current_interim = ''
                                else:
                                    current_interim = transcript
                            else:
                                if is_final:
                                    transcript_buffer.append(transcript)
                        elif is_final:
                            # Empty final transcript — reset interim
                            current_interim = ''

                # Handle speech started event
                if msg_type == 'SpeechStarted':
                    last_speech_time = time.time()
                    has_received_speech = True

            def on_error(error):
                print(f"\nError: {error}", file=sys.stderr)

            connection.on(EventType.MESSAGE, on_message)
            connection.on(EventType.ERROR, on_error)
            connection.on(EventType.OPEN, lambda _: print("Listening... (auto-stops after silence)", file=sys.stderr))
            connection.on(EventType.CLOSE, lambda _: print("\n", file=sys.stderr))

            # Start listening in background thread
            listen_thread = threading.Thread(target=connection.start_listening, daemon=True)
            listen_thread.start()

            try:
                while running:
                    try:
                        data = audio_queue.get(timeout=0.5)
                    except queue.Empty:
                        # If the capture thread died (mic disconnect, ALSA error)
                        # we'll never get more audio — bail out instead of hanging.
                        if not _capture_thread.is_alive() and capturing:
                            print("Mic capture thread died — exiting", file=sys.stderr)
                            subprocess.run(['notify-send', '-u', 'critical', 'Dictation Error', 'Mic capture stopped'])
                            running = False
                        continue
                    connection.send_media(data)

                    # Check for silence timeout (only after receiving some speech)
                    if has_received_speech and (time.time() - last_speech_time) > SILENCE_TIMEOUT:
                        running = False
                    # If no speech ever, give up after PRE_SPEECH_TIMEOUT
                    elif not has_received_speech and (time.time() - start_time) > PRE_SPEECH_TIMEOUT:
                        print("No speech detected — exiting", file=sys.stderr)
                        running = False
            except KeyboardInterrupt:
                pass
            finally:
                cleanup_and_exit()

    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        subprocess.run(['notify-send', '-u', 'critical', 'Dictation Error', str(e)])
        cleanup_and_exit()

if __name__ == "__main__":
    main()
